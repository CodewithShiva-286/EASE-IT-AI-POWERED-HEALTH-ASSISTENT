# EASE-IT Environment Configuration Example
# Copy this file to .env and fill in the actual values

# Server Port
PORT=10000

# MongoDB connection URI (e.g., mongodb+srv://username:password@cluster.mongodb.net/dbname)
DB_URI=your_mongodb_connection_string

# JWT secret key for signing tokens (long random string recommended)
JWT_SECRET=your_jwt_secret_key_here

# JWT token expiration (e.g., 1h, 1d)
JWT_EXPIRES_IN=1h

# Google Gemini API Key (from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Max JSON payload size
JSON_LIMIT=8mb

# Node Environment (development/production)
NODE_ENV=development
